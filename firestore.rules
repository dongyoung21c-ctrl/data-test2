rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidStrategy(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'quadrant', 'strategy', 'userId', 'userName', 'userSchool', 'createdAt'])
        && data.studentId is string && data.studentId.size() <= 64
        && data.studentName is string && data.studentName.size() > 0
        && data.quadrant in ['Q1', 'Q2', 'Q3', 'Q4']
        && data.strategy is string && data.strategy.size() > 0
        && (request.auth == null || data.userId == request.auth.uid)
        && data.createdAt == request.time;
    }

    match /artifacts/{appId} {
      allow read: if isValidId(appId);
      
      match /public/data/strategies/{strategyId} {
        allow list, get: if isValidId(appId);
        allow create: if isValidId(appId) && isValidStrategy(incoming());
        allow update: if false;
        allow delete: if isSignedIn() && isOwner(existing());
      }
    }
  }
}
