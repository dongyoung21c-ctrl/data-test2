rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidStrategy(data) {
      return data.keys().hasAll(['studentId', 'quadrant', 'strategy', 'userId', 'userName', 'userSchool', 'createdAt'])
        && data.studentId is string && data.studentId.size() <= 128
        && data.quadrant in ['Q1', 'Q2', 'Q3', 'Q4']
        && data.strategy is string && data.strategy.size() > 0 && data.strategy.size() <= 5000
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /artifacts/{appId} {
      allow read: if isValidId(appId);
      
      match /public/data/students/{studentId} {
        allow read: if isValidId(appId) && isValidId(studentId);

        match /strategies/{strategyId} {
          allow list: if isSignedIn() && isValidId(appId) && isValidId(studentId);
          allow get: if isSignedIn() && isValidId(appId) && isValidId(studentId);
          allow create: if isSignedIn() && isValidId(appId) && isValidId(studentId) && 
                         isValidStrategy(incoming()) && 
                         (incoming().studentId == studentId || !incoming().keys().hasAll(['studentId']));
          allow update: if false;
          allow delete: if isSignedIn() && isValidId(studentId) && isOwner(existing());
        }
      }
    }
  }
}
